<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScmMoM.UI.ViewModels"
        x:Class="ScmMoM.UI.Views.LoginWindow"
        Title="ScmMoM — Connect"
        Icon="avares://ScmMoM.UI/Assets/scmmom-icon.ico"
        SizeToContent="Height"
        Width="560"
        MinHeight="400"
        MaxHeight="900"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:LoginViewModel />
  </Design.DataContext>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
  <Border Padding="32,24">
    <StackPanel Spacing="12">

      <Image Source="avares://ScmMoM.UI/Assets/scmmom-icon.png"
             Width="100" Height="100"
             HorizontalAlignment="Center"
             Margin="0,0,0,4" />

      <TextBlock Text="ScmMoM — Source Code Monitor of Monitors"
                 FontSize="18" FontWeight="Bold"
                 HorizontalAlignment="Center"
                 TextWrapping="Wrap"
                 TextAlignment="Center" />

      <TextBlock Text="Configure your SCM accounts to get started."
                 HorizontalAlignment="Center"
                 Foreground="Gray" FontSize="12" />

      <Separator Margin="0,4" />

      <!-- Configured accounts list -->
      <TextBlock Text="Accounts" FontWeight="SemiBold" FontSize="14"
                 IsVisible="{Binding HasAccounts}" />
      <ItemsControl ItemsSource="{Binding AccountEntries}" IsVisible="{Binding HasAccounts}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="4,6" Margin="0,2">
              <StackPanel Spacing="4">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Text="{Binding StatusIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                             ToolTip.Tip="{Binding StatusTooltip}" />
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock FontWeight="SemiBold">
                      <Run Text="{Binding ProviderIcon}" /><Run Text=" " /><Run Text="{Binding DisplayName}" />
                    </TextBlock>
                    <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11" />
                  </StackPanel>
                  <Button Grid.Column="2" Content="✕" FontSize="10" Padding="4,2"
                          Command="{Binding RemoveCommand}" VerticalAlignment="Center" />
                </Grid>
                <!-- Inline token entry for accounts missing a token -->
                <Border IsVisible="{Binding NeedsToken}" Background="#1AFFFFFF" CornerRadius="4" Padding="8,6" Margin="0,2,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Enter token for this account:" FontSize="11" Foreground="Gray" />
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                      <TextBox Text="{Binding EditToken}" Watermark="Personal Access Token" PasswordChar="●" FontSize="12" />
                      <Button Grid.Column="1" Content="Save" Padding="10,4" Margin="6,0,0,0" FontSize="12"
                              Command="{Binding SaveTokenCommand}" />
                    </Grid>
                    <CheckBox Content="Remember token" IsChecked="{Binding RememberToken}" FontSize="11" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Separator Margin="0,4" IsVisible="{Binding HasAccounts}" />

      <!-- Add new account toggle -->
      <Button Content="{Binding AddFormButtonText}" Command="{Binding ToggleAddFormCommand}"
              HorizontalAlignment="Left" Padding="12,6" FontSize="13" />

      <!-- Collapsible Add Account form -->
      <Border IsVisible="{Binding IsAddFormVisible}" BorderBrush="Gray" BorderThickness="1"
              CornerRadius="4" Padding="12,10" Margin="0,4">
        <StackPanel Spacing="8">
          <TextBlock Text="New Account" FontWeight="SemiBold" FontSize="13" />

          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,4">
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,4">
              <TextBlock Text="Provider" FontSize="12" Margin="0,0,0,2" />
              <ComboBox Name="ProviderCombo" SelectedIndex="{Binding SelectedProviderIndex}" HorizontalAlignment="Stretch" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="6,0,0,4">
              <TextBlock Text="Display Name" FontSize="12" Margin="0,0,0,2" />
              <TextBox Text="{Binding NewDisplayName}" Watermark="My GitHub" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4"
                        IsVisible="{Binding ShowServerUrl}">
              <TextBlock Text="Server URL" FontSize="12" Margin="0,0,0,2" />
              <TextBox Text="{Binding NewServerUrl}" Watermark="https://gitlab.example.com" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,6,4">
              <TextBlock Text="Username" FontSize="12" Margin="0,0,0,2" />
              <TextBox Text="{Binding NewUsername}" Watermark="your-username" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="6,0,0,4">
              <TextBlock Text="Personal Access Token" FontSize="12" Margin="0,0,0,2" />
              <TextBox Text="{Binding NewToken}" Watermark="token..." PasswordChar="●" />
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
              <TextBlock Text="Organization / Group" FontSize="12" Margin="0,0,0,2" />
              <TextBox Text="{Binding NewOrganization}" Watermark="e.g. my-org" />
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
              <TextBlock Text="Repositories (comma-separated)" FontSize="12" Margin="0,0,0,2" />
              <TextBox Text="{Binding NewRepositories}" Watermark="repo1, repo2, ..." />
            </StackPanel>

            <CheckBox Grid.Row="5" Grid.Column="0" Content="Remember token" IsChecked="{Binding NewRememberToken}" />
          </Grid>

          <Button Content="Add" Command="{Binding AddAccountCommand}"
                  HorizontalAlignment="Left" Padding="16,6" />
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 TextWrapping="Wrap" />

      <ProgressBar IsIndeterminate="True"
                   IsVisible="{Binding IsConnecting}"
                   Height="4" />

      <Separator Margin="0,4" />

      <Button Content="Connect &amp; Launch"
              Command="{Binding ConnectCommand}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Classes="accent"
              Height="40"
              FontSize="15" />

    </StackPanel>
  </Border>
  </ScrollViewer>

</Window>
