<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScmMoM.UI.ViewModels"
        x:Class="ScmMoM.UI.Views.SettingsWindow"
        Title="ScmMoM — Settings"
        Icon="avares://ScmMoM.UI/Assets/bpm-icon.ico"
        Width="560" Height="700"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <Border Padding="24">
    <ScrollViewer>
    <StackPanel Spacing="14">

      <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" />
      <Separator />

      <!-- Per-account settings -->
      <TextBlock Text="Account Settings" FontWeight="SemiBold" FontSize="14" />
      <ItemsControl ItemsSource="{Binding AccountSettings}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,4">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding ProviderType}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding AccountId}" Foreground="Gray" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Display Name" FontSize="11" Foreground="Gray" />
                <TextBox Text="{Binding DisplayName}" />
                <TextBlock Text="Organization / Group" FontSize="11" Foreground="Gray" />
                <TextBox Text="{Binding Organization}" Watermark="e.g. my-org" />
                <TextBlock Text="Repositories (comma-separated)" FontSize="11" Foreground="Gray" />
                <TextBox Text="{Binding RepositoriesCsv}"
                         Watermark="repo1, repo2, ..."
                         AcceptsReturn="False" TextWrapping="Wrap" Height="50" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Separator />

      <TextBlock Text="Refresh Interval (seconds)" FontWeight="SemiBold" />
      <NumericUpDown Value="{Binding RefreshIntervalSeconds}"
                     Minimum="30"
                     Maximum="3600"
                     Increment="30"
                     FormatString="0" />

      <CheckBox Content="Enable desktop notifications"
                IsChecked="{Binding NotificationsEnabled}" />

      <Separator />

      <TextBlock Text="Theme" FontWeight="SemiBold" />
      <ComboBox SelectedItem="{Binding ThemeMode}" Width="200" Name="ThemeComboBox" />

      <Separator />

      <TextBlock Text="Web Dashboard" FontWeight="SemiBold" />
      <CheckBox Content="Enable web dashboard server"
                IsChecked="{Binding WebServerEnabled}" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Port:" VerticalAlignment="Center" />
        <NumericUpDown Value="{Binding WebServerPort}"
                       Minimum="1024"
                       Maximum="65535"
                       Increment="1"
                       FormatString="0"
                       Width="120" />
      </StackPanel>

      <Separator />

      <TextBlock Text="API Security (Pre-Shared Key)" FontWeight="SemiBold" />
      <TextBox Text="{Binding ApiPsk}" Watermark="Leave empty for no auth" />
      <Button Content="Generate PSK" Command="{Binding GeneratePskCommand}" Padding="8,4" HorizontalAlignment="Left" />

      <Separator />

      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="Green"
                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 TextWrapping="Wrap" />

      <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
        <Button Content="Save" Command="{Binding SaveCommand}" Classes="accent" Width="100" HorizontalContentAlignment="Center" />
        <Button Content="Close" Name="CloseButton" Width="100" HorizontalContentAlignment="Center" />
      </StackPanel>

    </StackPanel>
    </ScrollViewer>
  </Border>

</Window>
